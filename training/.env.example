# Christmas Air - Training (training.christmasair.com)
# Copy to .env.local for local dev; set the same in Vercel for deploys.

# --- Supabase (shared project dgnsvheokdubqmdlanua) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (shared SSO across *.christmasair.com) ---
NEXTAUTH_URL=http://localhost:3012
NEXTAUTH_SECRET=            # MUST match the other apps (shared SSO cookie)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAINS=christmasair.com

# --- Quo SMS (reused from ap-payments) ---
QUO_API_KEY=
QUO_FROM_NUMBER=+14694054121
QUO_USER_ID=

# --- Spike admin/cron secret (gates /api/spike/send and /api/spike/results) ---
CRON_SECRET=
