{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["app/**/*", "templates/**/*", "static/**/*"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/sync?hours_back=24", "schedule": "0 12 * * *" },
    { "path": "/api/sync?hours_back=2", "schedule": "0 14-23 * * 1-6" }
  ]
}
