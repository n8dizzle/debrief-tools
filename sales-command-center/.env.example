# Service Titan API Configuration
ST_CLIENT_ID=your_client_id
ST_CLIENT_SECRET=your_client_secret
ST_TENANT_ID=your_tenant_id
ST_APP_KEY=your_app_key
ST_ENVIRONMENT=production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Slack Bot (requires scopes: users:read.email, im:write, chat:write)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret

# Admin email for alerts (empty queue, failed notifications)
ADMIN_EMAIL=scott@christmasair.com

# Test Mode: when true, ALL Slack DMs go to TEST_DM_EMAILS instead of real advisors
# Set to false when going live
TEST_MODE=true
TEST_DM_EMAILS=scott@christmasair.com,nathan@christmasair.com

# Service Titan Web URL for job links
SERVICE_TITAN_WEB_URL=https://go.servicetitan.com

# Cron
CRON_SECRET=your_cron_secret

# Dashboard URL (auto-detected on Vercel)
# NEXT_PUBLIC_DASHBOARD_URL=https://sales.christmasair.com
