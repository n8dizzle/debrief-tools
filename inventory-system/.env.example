DATABASE_URL=postgresql://user:pass@host:5432/database

JWT_SECRET=replace_with_strong_random_string
JWT_REFRESH_SECRET=replace_with_different_strong_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional during migration only — points at the legacy Express API.
# After Phase 2 is fully complete, this should be unset.
# INVENTORY_API_BASE_URL=http://localhost:3100/api/v1
