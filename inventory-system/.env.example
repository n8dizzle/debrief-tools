DATABASE_URL=postgresql://user:pass@host:5432/database

# NextAuth
NEXTAUTH_URL=http://localhost:3011
NEXTAUTH_SECRET=replace_with_random_32+_byte_string

# Google OAuth — production sign-in. Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email+password Credentials fallback. Set "false" in production once Google
# OAuth is wired up.
NEXTAUTH_ALLOW_CREDENTIALS=true

# Cron — Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` automatically.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ServiceTitan API
ST_CLIENT_ID=
ST_CLIENT_SECRET=
ST_TENANT_ID=
ST_APP_KEY=
