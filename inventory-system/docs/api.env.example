# ─── REQUIRED — app will not start without these ─────────────────────────────

# Supabase pooler connection string (Settings → Database → Connection string → Pooler)
DATABASE_URL=postgresql://postgres.YOURPROJECTREF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# JWT signing secrets — generate with: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── OPTIONAL — warn on startup if missing, features gracefully disabled ─────

# ServiceTitan API credentials (leave as 'placeholder' if not configuring yet)
ST_CLIENT_ID=placeholder
ST_CLIENT_SECRET=placeholder
ST_TENANT_ID=placeholder
ST_APP_KEY=placeholder

# SendGrid (for low-stock email alerts)
SENDGRID_API_KEY=placeholder
FROM_EMAIL=noreply@christmasair.com
MANAGER_NOTIFY_EMAIL=ray@christmasair.com

# ─── SERVER CONFIG ────────────────────────────────────────────────────────────

PORT=3100
NODE_ENV=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# ─── SCHEDULED JOB OVERRIDES (cron syntax) ───────────────────────────────────
# Defaults shown — only set these if you want to override the schedule

# BATCH_LOCK_CRON=0 6 * * *     # 6:00 AM daily
# WEEKLY_PO_CRON=0 7 * * 1      # Monday 7:00 AM
# ST_SYNC_CRON=0 */4 * * *      # Every 4 hours
# BIN_ALERT_CRON=0 * * * *      # Every hour

# ─── JWT EXPIRY OVERRIDES ─────────────────────────────────────────────────────
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
