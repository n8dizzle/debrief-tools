# ─── FRONTEND ENVIRONMENT ────────────────────────────────────────────────────
#
# In DEVELOPMENT: leave this blank. The Vite dev server proxy in
# vite.config.js forwards /api/* to the API automatically.
#
# In PRODUCTION: set this to your deployed API URL so the frontend
# knows where to send requests.
#
# VITE_API_BASE_URL=https://api.christmasair.com/api
