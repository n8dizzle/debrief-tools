# ============================================================
# INVENTORY MANAGEMENT API — ENVIRONMENT VARIABLES
# Copy to .env and fill in values before running.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# ============================================================
# DATABASE
# ============================================================
DATABASE_URLpostgresql://postgres.duwnhudsomvdsyruzzoh:YQ3PSyDeJ4OcYm4m@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# ============================================================
# JWT
# ============================================================
JWT_SECRET=inventory_jwt_secret_key_2026_xK9mP2qR
JWT_REFRESH_SECRET=inventory_refresh_secret_key_2026_nL4wQ8vT
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# SERVICETITAN
# https://developer.servicetitan.io
# ============================================================
ST_CLIENT_ID=placeholder
ST_CLIENT_SECRET=placeholder
ST_TENANT_ID=placeholder
ST_APP_KEY=placeholder
# Sync job schedules (cron syntax, all times are local to server TZ)
ST_SYNC_CRON=0 */4 * * *

# ============================================================
# SENDGRID
# ============================================================
SENDGRID_API_KEY=placeholder
FROM_EMAIL=ray@christmasair.com
FROM_NAME=Inventory System
# Where PO-ready notifications are sent internally
MANAGER_NOTIFY_EMAIL=manager@yourcompany.com

# ============================================================
# SCHEDULER CRONS  (cron syntax — server local time)
# ============================================================
# Lock all collecting restock batches every morning at 6 AM
BATCH_LOCK_CRON=0 6 * * *
# Generate weekly POs every Monday at 7 AM
WEEKLY_PO_CRON=0 7 * * 1
# Check bin alerts every hour
BIN_ALERT_CRON=0 * * * *

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
PORT=3100
